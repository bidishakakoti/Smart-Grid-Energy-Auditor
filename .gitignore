# ──────────────────────────────────────────
#  SmartGridAuditor — .gitignore
# ──────────────────────────────────────────

# Compiled Binaries
SmartGridAuditor
SmartGridAuditor.exe

# Object files & static/shared libs
*.o
*.obj
*.a
*.so
*.dll
*.lib

# CMake build output
build/
cmake-build-debug/
cmake-build-release/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake

# Auto-generated data files (runtime output, not source)
data/audit_logs.txt
data/session.txt

# IDE & Editor settings
.vscode/
.idea/
*.suo
*.user
*.sln.docinfo
*.code-workspace
*.exe

# macOS junk
.DS_Store

# Windows junk
Thumbs.db
desktop.ini

# Dependency / package dirs (if any are added later)
deps/
third_party/
